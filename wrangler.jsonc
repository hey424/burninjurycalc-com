{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "burninjurycalc-com",
  "compatibility_date": "2026-05-18",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "main": "src/worker.ts",
  "routes": [
    {
      "pattern": "burninjurycalc.com/*",
      "zone_name": "burninjurycalc.com"
    },
    {
      "pattern": "www.burninjurycalc.com/*",
      "zone_name": "burninjurycalc.com"
    }
  ]
}
